# Entorno de la aplicación: development, production, test
NODE_ENV=production

# Puerto de la aplicación
PORT=3000

# Configuración de la base de datos PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=peso_tracker
DB_USER=peso_user
DB_PASSWORD=your_strong_password_here # Cambiar en producción

# Secreto para firmar los JWT (JSON Web Tokens)
# Usar un generador de contraseñas seguras para crear esto
# Ejemplo: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_that_is_long_and_random
JWT_EXPIRES_IN=7d

# Configuración de CORS (Cross-Origin Resource Sharing)
# Lista de orígenes permitidos separados por comas
# Ejemplo: http://localhost:5173,https://your-frontend-app.com
CORS_ORIGIN=http://localhost:3000

# Contraseña para pgAdmin
PGADMIN_DEFAULT_PASSWORD=your_pgadmin_password # Cambiar en producción